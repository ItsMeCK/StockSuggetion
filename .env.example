# .env example for Midnight Sovereign
# Database credentials
POSTGRES_USER=agent
POSTGRES_PASSWORD=agentpassword
POSTGRES_DB=sovereign_state
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# TimescaleDB credentials (market data)
TIMESCALE_USER=quant
TIMESCALE_PASSWORD=quantpassword
TIMESCALE_DB=market_data
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432

# Claude API
CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY

# Zerodha API
ZERODHA_API_KEY=YOUR_ZERODHA_API_KEY
ZERODHA_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
